# Global Vibez DSG Environment Template
NODE_ENV=development
PORT=3000

# Authentication
JWT_SECRET=your_jwt_secret_here

# Database / Storage
DATABASE_URL=your_db_connection_string_here

# Service Integrations
VIBEZ_API_KEY=your_api_key_here
REDIS_URL=redis://localhost:6379

# Logistical Services (Hunger Vibez / Vibez Spots)
LOGISTICS_SERVICE_ENDPOINT=https://api.vibe-logistics.com

# Site
NEXT_PUBLIC_SITE_URL=https://www.globalvibezdsg.com

# Chair-holder allow list (optional, comma-separated wallet addresses)
CHAIR_HOLDER_WALLETS=

# AI Provider Configuration (multi-provider routing via SovereignAgent)
AI_PROVIDER=ollama
OPENAI_API_KEY=your_openai_api_key_here
OPENAI_MODEL=gpt-4o
ANTHROPIC_API_KEY=your_anthropic_api_key_here
GEMINI_API_KEY=your_gemini_api_key_here
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3
CUSTOM_AI_ENDPOINT=https://your-custom-ai-endpoint.com/v1
CLYDE_ENDPOINT=your_custom_clyde_endpoint_here

# TV / Video Provider (mock | luma | runway | heygen)
TV_VIDEO_PROVIDER=mock
TV_VIDEO_API_KEY=your_tv_video_api_key_here
