# ─── Required ─────────────────────────────────────────────────────────────────
# Secret used to sign JWT session cookies.
# Generate with: openssl rand -base64 32
JWT_SECRET=your-secure-secret-here

# ─── Demo Login (local / staging only) ────────────────────────────────────────
# Set both vars to "true" to enable the "Demo Login (Quick Access)" button on
# the login page.  This lets you test protected routes (/dating, /dealer)
# without a real Solana wallet.
#
# WARNING: never set DEMO_LOGIN_ENABLED=true in production — it bypasses all
# wallet authentication.
#
# DEMO_LOGIN_ENABLED=true          # server-side guard (API route)
# NEXT_PUBLIC_DEMO_LOGIN_ENABLED=true  # shows the button in the UI
