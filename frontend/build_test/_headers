# Cache busting for React builds
# Static assets (hashed filenames) - cache forever
/static/*
  Cache-Control: public, max-age=31536000, immutable

# Service worker - always check for updates
/service-worker.js
  Cache-Control: no-cache, no-store, must-revalidate

# HTML - never cache (always fetch latest)
/*.html
  Cache-Control: no-cache, no-store, must-revalidate
  Pragma: no-cache
  Expires: 0

# Root index
/
  Cache-Control: no-cache, no-store, must-revalidate
  Pragma: no-cache
  Expires: 0

# Manifest - check hourly
/manifest.json
  Cache-Control: public, max-age=3600

# API calls - never cache
/api/*
  Cache-Control: no-cache, no-store, must-revalidate
